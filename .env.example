# =====================================================================
# ZAGAFY — Environment Variables
# =====================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env*` is in .gitignore — never commit secrets.
# =====================================================================

# ---------------------------------------------------------------------
# CURRENT (required to run the app)
# ---------------------------------------------------------------------

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN: Required for production rate limiting.
# Without these, rate limiting falls back to in-memory (ineffective on serverless).
# Get these from https://console.upstash.com after creating a Redis database.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ANTHROPIC_API_KEY: Required for the voice braindump "Polish" feature
# and the character chat endpoint.
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ANTHROPIC_MODEL: Override the Anthropic model used by /api/character-chat
# and /api/polish. Defaults to claude-sonnet-4-5-20250929.
# Centralizes model selection — see Phase 1 / CB-01.
# ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# HEALTH_TOKEN: Required in production to access /api/health/rate-limit.
# The endpoint compares this against the X-Health-Token request header.
# In production WITHOUT this set, the endpoint returns 503.
# In dev / test, the endpoint is open when this is unset.
# HEALTH_TOKEN=""

# ---------------------------------------------------------------------
# Phase 5+ — SaaS infrastructure (not required for AI Studio applet)
# Uncomment as features land.
# ---------------------------------------------------------------------

# Auth — Clerk (Phase 5.2)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""

# Database — Neon Postgres + Drizzle (Phase 5.3)
# DATABASE_URL=""

# Billing — Stripe (Phase 5.7)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Error tracking — Sentry (Phase 5.1)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Product analytics — PostHog (Phase 5.8)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# Transactional email — Resend (Phase 5.10)
# RESEND_API_KEY=""
