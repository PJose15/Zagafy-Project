# =====================================================================
# ZAGAFY — Environment Variables
# =====================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env*` is in .gitignore — never commit secrets.
# =====================================================================

# ---------------------------------------------------------------------
# CURRENT (required to run the app)
# ---------------------------------------------------------------------
#
# AI FEATURE AVAILABILITY (read this if "AI does nothing" in production):
#  - Most AI (assistant, coach, micro-prompt, publishing, ingest) needs
#    GEMINI_API_KEY. Character Chat needs ANTHROPIC_API_KEY.
#  - These must be set in your HOSTING env (e.g. Vercel project settings),
#    not just .env.local — otherwise routes return 500 and the app shows a
#    "not configured" banner.
#  - For NO login wall, leave Clerk keys unset OR set
#    NEXT_PUBLIC_DEPLOYMENT_MODE="embed" so requireUser() never 401s.
#  - /api/ai-status reports presence booleans (no values) for the UI banner.

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# UPSTASH_REDIS_REST_URL and UPSTASH_REDIS_REST_TOKEN: Required for production rate limiting.
# Without these, rate limiting falls back to in-memory (ineffective on serverless).
# Get these from https://console.upstash.com after creating a Redis database.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ANTHROPIC_API_KEY: Required for the voice braindump "Polish" feature
# and the character chat endpoint.
# Get your API key from https://console.anthropic.com
ANTHROPIC_API_KEY=""

# ANTHROPIC_MODEL: Override the Anthropic model used by /api/character-chat
# and /api/polish. Defaults to claude-sonnet-4-6.
# Centralizes model selection — see Phase 1 / CB-01.
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# HEALTH_TOKEN: Required in production to access /api/health/rate-limit.
# The endpoint compares this against the X-Health-Token request header.
# In production WITHOUT this set, the endpoint returns 503.
# In dev / test, the endpoint is open when this is unset.
# HEALTH_TOKEN=""

# ---------------------------------------------------------------------
# Phase 5+ — SaaS infrastructure (not required for AI Studio applet)
# Uncomment as features land.
# ---------------------------------------------------------------------

# Auth — Clerk (Phase 5.2)
# Setup runbook: docs/CLERK_SETUP.md
# When NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY is set AND DEPLOYMENT_MODE is not 'embed',
# Clerk wraps the app, the middleware enforces sign-in on every page except
# /sign-in, /sign-up, /api/health(*), and every protected /api/* route requires
# a session via lib/auth.ts → requireUser().
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
# CLERK_SECRET_KEY=""

# DEPLOYMENT_MODE: 'embed' = AI Studio applet (auth bypassed even if Clerk
# keys are present). Anything else (or unset) = SaaS mode; auth enforced
# whenever Clerk keys are configured.
# NEXT_PUBLIC_DEPLOYMENT_MODE="embed"

# Database — Neon Postgres + Drizzle (Phase 5.3)
# Setup runbook: docs/NEON_SETUP.md
# Format: postgresql://user:password@host/dbname?sslmode=require
# DATABASE_URL=""

# Clerk webhook signing secret (Phase 5.3)
# Get this from Clerk Dashboard → Webhooks → your endpoint → Signing Secret.
# Used by /api/webhooks/clerk to verify Svix-signed payloads from Clerk.
# CLERK_WEBHOOK_SECRET=""

# Billing — Stripe (Phase 5.7)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Stripe Price IDs — create products in Stripe Dashboard, then paste price IDs here.
# STRIPE_PRICE_WRITER_MONTHLY=""
# STRIPE_PRICE_WRITER_YEARLY=""
# STRIPE_PRICE_AUTHOR_MONTHLY=""
# STRIPE_PRICE_AUTHOR_YEARLY=""
# STRIPE_PRICE_STUDIO_MONTHLY=""
# STRIPE_PRICE_STUDIO_YEARLY=""

# Error tracking — Sentry (Phase 5.1)
# Setup runbook: docs/SENTRY_SETUP.md
# DSN is safe to expose — paste the same value into both vars.
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN=""
# Auth token + org/project are required only at build time (source-map upload).
# Generate token at https://sentry.io/orgredirect/settings/auth-tokens/ with project:releases scope.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Product analytics — PostHog (Phase 5.8)
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# Transactional email — Resend (Phase 5.10)
# RESEND_API_KEY=""

# CRON_SECRET: Protects /api/cron/onboarding (day 1/3/7 drip emails).
# Vercel automatically sends `Authorization: Bearer ${CRON_SECRET}` with cron
# invocations when this is set in the Vercel project env. REQUIRED in
# production (route returns 500 without it); optional in dev (route is open).
# Generate with: openssl rand -hex 32
# CRON_SECRET=""

# Observability — Metrics & Alerts (Phase 5.11)
# See docs/RUNBOOK.md for alert configuration and on-call procedures.
# DAILY_AI_SPEND_ALERT_CENTS: When a single AI call's estimated cost exceeds
# this value (in cents), a warning is logged and forwarded to Sentry.
# Example: 1000 = $10. Leave unset or 0 to disable per-call alerting.
# Aggregate daily spend is tracked via PostHog dashboards.
# DAILY_AI_SPEND_ALERT_CENTS=""
